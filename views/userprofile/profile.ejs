<script>
    // change password script ==========================
$(document).ready(function() {
    $("#btn-save-changes").click(function() {
        var currentPassword = $("#current-password").val();
        var newPassword = $("#new-password").val();
        var repeatNewPassword = $("#repeat-new-password").val();

        if (currentPassword === '' || newPassword === '' || repeatNewPassword === '') {
            alert("Please fill in all fields.");
            return;
        }

        if (newPassword !== repeatNewPassword) {
            alert("New password and repeated new password do not match.");
            return;
        }

        $.ajax({
            url: "/change-password",
            method: "POST",
            data: {
                currentPassword: currentPassword,
                newPassword: newPassword,
                repeatNewPassword: repeatNewPassword 
            },
            success: function(response) {
                alert(response.message);
                window.location.reload(); 
            },
            error: function(xhr, status, error) {
                alert(xhr.responseJSON.error);
            }
        });
    });
});

// change password script end=========================

//==========================Address script=============
// Assume jQuery is included

$(document).ready(function() {
    // Handle form submission
    $('#address-form').submit(function(event) {
        event.preventDefault();
        var formData = $(this).serialize();
        
        // Send AJAX request to save address
        $.post('/save-address', formData, function(response) {
            // Handle response, maybe display a success message
            // Clear form fields
            $('#address-form')[0].reset();
            // Reload address list
            loadAddressList();
            addAddress();
        });
    });

    function addAddress() {
    // Your code to handle form submission and address addition goes here
    
    // Assuming the address is added successfully, show the success message
    document.getElementById("address-success-message").style.display = "inline";
}
    
    // Load address list on page load
    loadAddressList();
    
    // Function to load and display address list
    function loadAddressList() {
        $.get('/get-addresses', function(addresses) {
            var addressListHtml = '';
            addresses.forEach(function(address) {
                addressListHtml += '<div class="card-body pb-2">';
                addressListHtml += '<p>Mobile: ' + address.mobile + '</p>';
                addressListHtml += '<p>Email: ' + address.email + '</p>';
                // Include other address fields as needed
                addressListHtml += '<div class="text-right mt-3">';
                addressListHtml += '<button type="button" class="btn btn-primary btn-edit" data-id="' + address._id + '">Edit</button>';
                addressListHtml += '<button type="button" class="btn btn-danger btn-delete" data-id="' + address._id + '">Delete</button>';
                addressListHtml += '</div>';
                addressListHtml += '</div>';
            });
            $('#address-list').html(addressListHtml);
        });
    }
    
    // Handle edit button click
    $('#address-list').on('click', '.btn-edit', function() {
        var addressId = $(this).data('id');
        // Fetch address details and populate form fields for editing
        $.get('/get-address/' + addressId, function(address) {
            // Populate form fields with address details for editing
            $('#address-form input[name="mobile"]').val(address.mobile);
            $('#address-form input[name="email"]').val(address.email);
            // Populate other fields similarly
            // Change submit button to Update instead of Add Address
            $('#btn-save-address').text('Update').attr('id', 'btn-update-address');
        });
    });
    
    // Handle update button click
    $('#address-form').on('click', '#btn-update-address', function() {
        // Similar to handling form submission, but this time update the existing address instead of adding a new one
        // You need to send the address ID along with the updated data
        // Then reload the address list
    });
    
    // Handle delete button click
    $('#address-list').on('click', '.btn-delete', function() {
        var addressId = $(this).data('id');
        // Send AJAX request to delete address
        $.post('/delete-address/' + addressId, function(response) {
            // Handle response, maybe display a success message
            // Reload address list
            loadAddressList();
        });
    });
    
    // Handle cancel button click
    $('#btn-cancel').click(function() {
        // Clear form fields
        $('#address-form')[0].reset();
        // Reset submit button to Add Address
        $('#btn-update-address').text('Add Address').attr('id', 'btn-save-address');
    });
});





//============end address====================




</script>








<script>
    document.getElementById('btn-add-address').addEventListener('click', function() {
        var form = document.getElementById('address-form');
        var addButton = document.getElementById('btn-add-address');
        if (form.style.display === 'none') {
            form.style.display = 'block';
            addButton.style.display = 'none'; // Hide the button
        } else {
            form.style.display = 'none';
            addButton.style.display = 'block'; // Show the button again
        }
    });

    document.getElementById('btn-cancel').addEventListener('click', function() {
        document.getElementById('address-form').style.display = 'none';
        document.getElementById('btn-add-address').style.display = 'block'; // Show the button again
    });
</script>



<script>
    document.getElementById("btn-save-address").addEventListener("click", function(event) {
        var form = document.getElementById("address-form");
        var inputs = form.querySelectorAll("input");
        var isValid = true;

        inputs.forEach(function(input) {
            if (input.value.trim() === "") {
                isValid = false;
                input.classList.add("is-invalid");
            } else {
                input.classList.remove("is-invalid");
            }
        });

        if (!isValid) {
            event.preventDefault();
            alert("Please fill out all fields.");
        }
    });
</script>

