<!-- Updated removeItem function in the script section -->
<script>
    function removeItem(button) {
        const productId = button.getAttribute('data-product-id');
        $.ajax({
          url: `/removeItem/${productId}`,
          type: 'DELETE',
          success: function(response) {
            if (response.success) {
              // Remove the item from the UI without reloading the page
            //   $(button).closest('.main').remove();
              // You can also update any summary or total price if needed
            } else {
              // Handle error response
              console.error(response.message);
            }
          },
          error: function(xhr, status, error) {
            console.error(error);
          }
        });
    }
    

    </script>
    



    <script>
    function increaseQuantity(button) {
        const quantityInput = $(button).siblings('.quantity-input');
        const currentQuantity = parseInt(quantityInput.val());
        const newQuantity = currentQuantity + 1;
        quantityInput.val(newQuantity);
        
        const priceDisplay = $(button).closest('.main').find('.price');
        const unitPrice = parseInt(priceDisplay.attr('data-unit-price'));
        const totalPrice = unitPrice * newQuantity;
        priceDisplay.text('₹ ' + totalPrice.toFixed(2));

        updateTotalPrice();
    }

    function decreaseQuantity(button) {
        const quantityInput = $(button).siblings('.quantity-input');
        const currentQuantity = parseInt(quantityInput.val());
        if (currentQuantity > 1) {
            const newQuantity = currentQuantity - 1;
            quantityInput.val(newQuantity);
            
            const priceDisplay = $(button).closest('.main').find('.price');
            const unitPrice = parseInt(priceDisplay.attr('data-unit-price'));
            const totalPrice = unitPrice * newQuantity;
            priceDisplay.text('₹ ' + totalPrice.toFixed(2));

            updateTotalPrice();
        }
    }

    function updateTotalPrice() {
    let totalPrice = 0;
    $('.price').each(function() {
        const priceText = $(this).text().replace('₹ ', ''); // Remove currency symbol
        const price = parseFloat(priceText); // Parse price as float
        if (!isNaN(price)) { // Check if price is a valid number
            totalPrice += price; // Add to total price
        }
    });
    $('#total-price').text('₹ ' + totalPrice.toFixed(2)); // Format total price with 2 decimal places
}
</script>




 
    
    



