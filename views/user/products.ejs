<style>
    body {
        align-items: center;
        justify-content: center;
        height: 100vh;
        margin: 0;
        background-color: #ffffff;
        max-width: 100%;
        overflow-x: hidden;
        font-family: serif;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        margin-bottom: 30px;
        margin-left: 45px;
        margin-right: 45px;
    }

    .container {
        width: 24%;
        margin: 10px;
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        background-color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.125);
        padding: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: transform 0.3s ease;
        border-radius: 9px 9px 9px 9px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        filter: drop-shadow(0 10px 5px rgba(2, 4, 8, 0.125));
    }


    .banner-image {
        background-position: center;
        background-size: cover;
        height: 150px;
        width: 100%;
        transition: transform 0.3s ease;
        border-radius: 9px 9px 9px 9px;
        object-fit: cover;
    }

    .container:hover .banner-image {
        transform: scale(1.060);
    }

    h5 {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        color: rgba(0, 0, 0, 0.98);
        text-transform: uppercase;
        font-size: 1rem;
        margin-top: 10px;
    }

    h5.card-title {
        margin-top: 0;
    }

    p {
        color: #000000;
        font-family: serif;
        text-align: center;
        font-size: 0.8rem;
        line-height: 150%;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .button-wrapper {
        margin-top: 10px;
    }

    .btn {
        border: none;
        padding: 8px 16px;
        border-radius: 7px;
        font-size: 0.8rem;
        letter-spacing: 1px;
        cursor: pointer;
    }

    .btn + .btn {
        margin-left: 10px;
    }

    .outline {
        /* background: transparent; */
        color: rgba(255, 255, 255, 0.9);
        /* border: 1px solid rgba(0, 212, 255, 0.6); */
        transition: all 0.3s ease;
        background-color: rgb(43, 95, 73);
    }

    .outline:hover {
        color: rgba(255, 255, 255, 0.9);
        border-color: rgba(22, 65, 36, 0.9);
        transition: all 0.3s ease;
        background-color: rgb(15, 55, 38);

    }

    .fill {
        /* background: transparent; */
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(33, 87, 65, 0.6);
        transition: all 0.3s ease;
        background-color: rgb(43, 95, 73);

    }

    .fill:hover {
        color: rgba(255, 255, 255, 0.9);
        border-color: rgba(22, 65, 36, 0.9);
        transition: all 0.3s ease;
        background-color: rgb(15, 55, 38);

    }

    @media screen and (min-width: 769px) {
        .container {
            width: 23%;
        }

        .banner-image {
            height: 220px;
        }
    }

    @media screen and (max-width: 768px) {
        .container {
            width: 48%;
        }

        .banner-image {
            height: 120px;
        }
    }

    @media screen and (max-width: 480px) {
        .container {
            width: 100%;
        }

        .banner-image {
            height: 100px;
        }
    }



    /* Dropdown Button */
.dropbtn {
  background-color: #ffffff;
;
  color: rgb(0, 0, 0);
  padding: 3px;
  font-size: 16px;
  border: none;
  cursor: pointer;

}

/* Dropdown button on hover & focus */
.dropbtn:hover, .dropbtn:focus {
  background-color: #ffffff;
  color: #000000;
  /* border: 1px solid black; */
  
}



/* The container <div> - needed to position the dropdown content */
.dropdown {
  position: relative;
  display: inline-block;
}

/* Dropdown Content (Hidden by Default) */
.dropdown-content {
  display: none;
  position: absolute;
  background-color: #f6f6f6;
  min-width: 230px;
  border: 1px solid #ddd;
  z-index: 1;
}

/* Links inside the dropdown */
.dropdown-content a {
  color: black;
  padding: 12px 16px;
  text-decoration: none;
  display: block;
}

/* Change color of dropdown links on hover */
.dropdown-content a:hover {background-color: #f1f1f1}

/* Show the dropdown menu (use JS to add this class to the .dropdown-content container when the user clicks on the dropdown button) */
.show {display:block;}


.dropmargin{
    margin-left: 60px;
}

.input-group {
    display: flex;
    align-items: center;
    margin-left: 54px;
}

.input-group input[type="search"] {
    flex: 1;
