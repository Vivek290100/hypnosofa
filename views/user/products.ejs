<% products.forEach((product, index) => { %>
    <% if (index % 4 === 0) { %>
        <div class="row">
    <% } %>
    <div class="container">
        <% if (product.images.length > 0) { %>
            <img src="/assets/product-images/<%= product.images[0] %>" class="banner-image" id="image-zoom" alt="<%= product.name %>"
                onclick="openModal('<%= product.images[0] %>')"><br>
        <% } else { %>
            <img src="/assets/default-image.jpg" class="banner-image" id="image-zoom" alt="Default Image"><br>
        <% } %>
        <h5 class="card-title"><%= product.name %></h5>
        <h5><%= "₹" + product.price %></h5>
        <div class="button-wrapper">
            <a href="/user/mainproduct/<%= product._id %>">  <button class="btn outline" >DETAILS</button>
            </a>
            <button class="btn fill">BUY NOW</button>
        </div>
    </div>
    <% if ((index + 1) % 4 === 0 || (index + 1) === products.length) { %>
        </div>
    <% } %>
<% }); %>











<script>
    /* When the user clicks on the button,
toggle between hiding and showing the dropdown content */
function myFunction() {
  document.getElementById("myDropdown").classList.toggle("show");
}

function filterFunction() {
  var input, filter, ul, li, a, i;
  input = document.getElementById("myInput");
  filter = input.value.toUpperCase();
  div = document.getElementById("myDropdown");
  a = div.getElementsByTagName("a");
  for (i = 0; i < a.length; i++) {
    txtValue = a[i].textContent || a[i].innerText;
    if (txtValue.toUpperCase().indexOf(filter) > -1) {
      a[i].style.display = "";
    } else {
      a[i].style.display = "none";
    }
  }
}
</script>



    
