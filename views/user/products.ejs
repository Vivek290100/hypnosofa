<% if (products.length === 0) { %>
  <div class="notfound d-flex justify-content-center align-items-center">  Sorry, No results found  !</div>
  <% } else { %>
  <% products.forEach((product, index) => { %>
      <% if (index % 4 === 0) { %>
          <div class="row">
      <% } %>
      <div class="container">
          <% if (product.images.length > 0) { %>
              <img src="/assets/product-images/<%= product.images[0] %>" class="banner-image" id="image-zoom" alt="<%= product.name %>"
                  onclick="openModal('<%= product.images[0] %>')"><br>
          <% } else { %>
              <img src="/assets/default-image.jpg" class="banner-image" id="image-zoom" alt="Default Image"><br>
          <% } %>
          <h5 class="card-title"><%= product.name %></h5>
          <h5><%= "₹" + product.price %></h5>
          <div class="button-wrapper">
              <a href="/user/mainproduct/<%= product._id %>">  
                  <button class="btn outline">DETAILS</button>
              </a>
              <a href="/user/addtocart/<%= product._id %>">  
                  <button class="btn fill">ADD TO CART</button>
              </a>
          </div>
      </div>
      <% if ((index + 1) % 4 === 0 || (index + 1) === products.length) { %>
          </div>
      <% } %>
  <% }); %>
<% } %>












<script>
    /* When the user clicks on the button,
toggle between hiding and showing the dropdown content */
function myFunction() {
  document.getElementById("myDropdown").classList.toggle("show");
}


</script>

<script>
    window.onclick = function(event) {
  if (!event.target.matches('.dropbtn') && !event.target.matches('#myInput')) {
    var dropdowns = document.getElementsByClassName("dropdown-content");
    for (var i = 0; i < dropdowns.length; i++) {
      var openDropdown = dropdowns[i];
      if (openDropdown.classList.contains('show')) {
        openDropdown.classList.remove('show');
      }
    }
  }
}
</script>





    
