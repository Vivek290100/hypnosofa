        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.5);
        /* border-radius: 29px; */
    }

    .carousel-control-prev,
    .carousel-control-next {
        font-size: 1.5em;
        animation: blink 1s infinite;
    }

    .getnow{
        backdrop-filter: blur(8px);

    }

    @keyframes blink {
        0%, 100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }

    @media (max-width: 767px) {
    .carousel-item .custom-carousel-content {
        width: 90%;
    }
}





