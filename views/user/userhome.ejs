<style>
    body {
        align-items: center;
        justify-content: center;
        height: 100vh;
        margin: 0;
        background-color: #a7bcb3;
        max-width: 100%;
        overflow-x: hidden;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        margin-bottom: 30px;
        margin-top: 30px;
        margin-left: 45px;
        margin-right: 45px;
    }

    .container {
        width: 23%;
        margin: 10px;
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        background-color: #e8e8e8;
        border: 1px solid rgba(255, 255, 255, 0.125);
        padding: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: transform 0.3s ease;
        /* border-radius: 9px 9px 9px 9px; */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        filter: drop-shadow(0 10px 5px rgba(2, 4, 8, 0.125));
    }

    /* .container:hover {
        transform: scale(1.01);
       
    } */

    .banner-image {
        background-position: center;
        background-size: cover;
        height: 150px;
        width: 100%;
        transition: transform 0.3s ease;
    }

    .container:hover .banner-image {
        transform: scale(1.070);
    }

    h5 {
        font-family: 'Righteous', sans-serif;
        color: rgba(0, 0, 0, 0.98);
        text-transform: uppercase;
        font-size: 1rem;
        margin-top: 10px;
    }

    h5.card-title {
        margin-top: 0;
    }

    p {
        color: #000000;
        font-family: 'Lato', sans-serif;
        text-align: center;
        font-size: 0.8rem;
        line-height: 150%;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .button-wrapper {
        margin-top: 10px;
    }

    .btn {
        border: none;
        padding: 8px 16px;
        border-radius: 24px;
        font-size: 0.8rem;
        letter-spacing: 2px;
        cursor: pointer;
    }

    .btn + .btn {
        margin-left: 10px;
    }

    .outline {
        /* background: transparent; */
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(0, 212, 255, 0.6);
        transition: all 0.3s ease;
        background-color: rgb(43, 95, 73);
    }

    .outline:hover {
        color: rgba(255, 255, 255, 0.9);
        border-color: rgba(22, 65, 36, 0.9);
        transition: all 0.3s ease;
        background-color: rgb(15, 55, 38);

    }

    .fill {
        /* background: transparent; */
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(33, 87, 65, 0.6);
        transition: all 0.3s ease;
        background-color: rgb(43, 95, 73);

    }

    .fill:hover {
        color: rgba(255, 255, 255, 0.9);
        border-color: rgba(22, 65, 36, 0.9);
        transition: all 0.3s ease;
        background-color: rgb(15, 55, 38);

    }

    @media screen and (min-width: 769px) {
        .container {
            width: 23%;
        }

        .banner-image {
            height: 220px;
        }
    }

    @media screen and (max-width: 768px) {
        .container {
            width: 48%;
        }

        .banner-image {
            height: 120px;
        }
    }

    @media screen and (max-width: 480px) {
        .container {
            width: 100%;
        }

        .banner-image {
            height: 100px;
        }
    }

</style>


<% products.forEach((product, index) => { %>
    <% if (index % 4 === 0) { %>
        <div class="row">
    <% } %>
    <div class="container">
        <% if (product.images && product.images.length > 0) { %>
            <img src="/assets/product-images/<%= product.images[0] %>" class="banner-image" id="image-zoom" alt="<%= product.name %>"
                onclick="openModal('<%= product.images[0] %>')"><br>
        <% } else { %>
            <img src="/assets/default-image.jpg" class="banner-image" id="image-zoom" alt="Default Image"><br>
        <% } %>
        <h5 class="card-title"><%= product.name %></h5>
        <h5><%= "₹" + product.price %></h5>
        <div class="button-wrapper">
            <a href="/user/mainproduct/<%= product._id %>"><button class="btn outline">DETAILS</button></a>
            <button class="btn fill">BUY NOW</button>
        </div>
    </div>
    <% if ((index + 1) % 4 === 0 || (index + 1) === products.length) { %>
        </div>
    <% } %>
<% }); %>
















